{
  "name": "qa-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:api && npm run test:ui && npm run test:bdd && npm run test:perf && npm run allure:generate && npm run allure:open",
    "test:api": "playwright test tests/api",
    "test:ui": "playwright test tests/ui",
    "test:ui:checkout": "npx playwright test tests/ui/ui-checkout.spec.js",
    "test:ui:integration": "npx playwright test tests/ui/ui-integration.spec.js",
    "test:bdd": "cucumber-js tests/api/bdd/api-tests.feature --require tests/api/steps/api.steps.cjs --format progress --format allure-cucumberjs/reporter",
    "test:perf": "k6 run --summary-export=performance/k6-summary.json performance/api-load.js && node ./scripts/k6-to-allure.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "node ./scripts/open-allure.js",
    "allure:serve": "npx allure serve allure-results",
    "report": "playwright show-report",
    "clean": "rimraf playwright-report allure-report allure-results node_modules"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "ajv": "^8.12.0",
    "allure-commandline": "^2.16.1",
    "allure-playwright": "^2.0.0",
    "allure-cucumberjs": "^3.10.2",
    "dotenv": "^16.3.1",
    "rimraf": "^5.0.0"
  }
}
